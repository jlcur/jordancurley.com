---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogList from "../components/BlogList.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
---

<BaseLayout pageTitle="Jordan Curley">
  <main class="flex flex-col my-6 px-4 sm:px-0">
    <header class="max-w-2xl">
      <h1 class="text-4xl sm:text-5xl font-bold text-black dark:text-white">
        Hi, I'm <span class="text-primary">Jordan</span>
      </h1>
      <p class="mt-4 text-lg sm:text-xl text-foreground leading-relaxed">
        I'm a software developer focused on building full-stack applications and
        learning new things.
      </p>
    </header>

    <!--<hr class="border-grey/20 my-12" />-->

    <!--&lt;!&ndash;<section aria-labelledby="blog-section">&ndash;&gt;-->
    <!--&lt;!&ndash;  <h2 id="blog-section" class="text-3xl mb-6">Articles</h2>&ndash;&gt;-->
    <!--&lt;!&ndash;  <BlogList />&ndash;&gt;-->
    <!--&lt;!&ndash;</section>&ndash;&gt;-->

    <hr class="border-grey/20 my-12" />

    <section aria-labelledby="projects-section">
      <h2 id="projects-section" class="text-3xl mb-6">Projects</h2>
      <ProjectGrid />
    </section>
  </main>
</BaseLayout>
